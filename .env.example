# KlimCode Configuration
# Copy this file to .env and fill in your values

# ============================================
# NVIDIA NIM API (Required)
# Get your free API key at https://build.nvidia.com
# ============================================
KLIMCODE_NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Server Configuration
# ============================================
KLIMCODE_PORT=7700
KLIMCODE_HOST=0.0.0.0
KLIMCODE_SECRET=change-this-to-a-random-secret-string

# ============================================
# GitHub Integration (Optional)
# Create a GitHub App or OAuth App for PR features
# ============================================
KLIMCODE_GITHUB_CLIENT_ID=
KLIMCODE_GITHUB_CLIENT_SECRET=
KLIMCODE_GITHUB_APP_ID=
KLIMCODE_GITHUB_PRIVATE_KEY_PATH=
KLIMCODE_GITHUB_WEBHOOK_SECRET=

# ============================================
# Database
# ============================================
KLIMCODE_DB_PATH=./data/klimcode.db

# ============================================
# Agent Sandbox Configuration
# ============================================
KLIMCODE_SANDBOX_DIR=./data/sandboxes
KLIMCODE_MAX_SANDBOX_SIZE_MB=500
KLIMCODE_SANDBOX_TIMEOUT_MS=30000
