# KlimCode Environment Variables
# These go in your Vercel Dashboard > Settings > Environment Variables
# DO NOT commit real values to git!

# ── Required ──
# Get your free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub OAuth App ──
# Create one at https://github.com/settings/applications/new
# Set callback URL to: https://your-app.vercel.app/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Vercel Postgres ──
# Auto-set when you add Postgres storage in Vercel Dashboard
# POSTGRES_URL is set automatically by Vercel

# ── Security (REQUIRED for production) ──
# Generate a random string: openssl rand -hex 32
# This is used to encrypt API keys and sensitive data in the database
# WARNING: You MUST change this before deploying to production!
KLIMCODE_SECRET=change-this-to-a-random-string

# ── GitHub Webhooks (optional) ──
# Required if you want to receive webhook events from GitHub
# Generate a random string: openssl rand -hex 32
KLIMCODE_GITHUB_WEBHOOK_SECRET=
